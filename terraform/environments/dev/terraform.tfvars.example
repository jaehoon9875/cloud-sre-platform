# dev 환경 변수 예시 파일
# 사용 방법:
#   1. 이 파일을 terraform/ 루트에 terraform.tfvars 로 복사
#   2. project_id 를 실제 GCP 프로젝트 ID로 교체
#   3. terraform init && terraform plan 실행
#
# terraform.tfvars 는 .gitignore 처리되어 있으므로 커밋되지 않음

# ── 필수 입력값 (직접 수정 필요) ──────────────────────────────────────────────
project_id = "cloud-sre-platform-dev"

# ── 선택 입력값 (기본값 사용 가능) ───────────────────────────────────────────
region      = "asia-northeast3"
environment = "dev"

# VPC
vpc_name      = "sre-platform-vpc"
subnet_cidr   = "10.0.1.0/24"
pods_cidr     = "10.1.0.0/16"
services_cidr = "10.2.0.0/20"

# Artifact Registry
repository_id = "sre-platform"

# GKE
cluster_name   = "sre-platform-cluster"
machine_type   = "e2-standard-2"
min_node_count = 0
max_node_count = 3
